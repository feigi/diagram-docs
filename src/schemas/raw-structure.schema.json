{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RawStructure",
  "description": "Output of diagram-docs scan command",
  "type": "object",
  "required": ["version", "scannedAt", "checksum", "applications"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "scannedAt": { "type": "string", "format": "date-time" },
    "checksum": { "type": "string" },
    "applications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "name",
          "language",
          "buildFile",
          "modules",
          "externalDependencies",
          "internalImports"
        ],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "name": { "type": "string" },
          "language": {
            "type": "string",
            "enum": ["java", "python", "c", "typescript"]
          },
          "buildFile": { "type": "string" },
          "modules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "path",
                "name",
                "files",
                "exports",
                "imports",
                "metadata"
              ],
              "properties": {
                "id": { "type": "string" },
                "path": { "type": "string" },
                "name": { "type": "string" },
                "files": { "type": "array", "items": { "type": "string" } },
                "exports": { "type": "array", "items": { "type": "string" } },
                "imports": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["source", "isExternal"],
                    "properties": {
                      "source": { "type": "string" },
                      "resolved": { "type": "string" },
                      "isExternal": { "type": "boolean" }
                    }
                  }
                },
                "metadata": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "codeElements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "kind", "name", "location"],
                    "properties": {
                      "id": { "type": "string" },
                      "kind": {
                        "type": "string",
                        "enum": [
                          "class",
                          "interface",
                          "enum",
                          "type",
                          "function",
                          "struct",
                          "typedef"
                        ]
                      },
                      "qualifiedName": { "type": "string" },
                      "name": { "type": "string" },
                      "visibility": {
                        "type": "string",
                        "enum": ["public", "internal", "private"]
                      },
                      "members": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["name", "kind"],
                          "properties": {
                            "name": { "type": "string" },
                            "kind": {
                              "type": "string",
                              "enum": ["field", "method"]
                            },
                            "signature": { "type": "string" },
                            "visibility": {
                              "type": "string",
                              "enum": ["public", "internal", "private"]
                            }
                          }
                        }
                      },
                      "tags": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "references": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["targetName", "kind"],
                          "properties": {
                            "targetName": { "type": "string" },
                            "targetQualifiedName": { "type": "string" },
                            "kind": {
                              "type": "string",
                              "enum": [
                                "extends",
                                "implements",
                                "uses",
                                "contains"
                              ]
                            }
                          }
                        }
                      },
                      "location": {
                        "type": "object",
                        "required": ["file", "line"],
                        "properties": {
                          "file": { "type": "string" },
                          "line": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "externalDependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "version": { "type": "string" }
              }
            }
          },
          "internalImports": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "sourceModuleId",
                "targetApplicationId",
                "targetPath"
              ],
              "properties": {
                "sourceModuleId": { "type": "string" },
                "targetApplicationId": { "type": "string" },
                "targetPath": { "type": "string" }
              }
            }
          },
          "publishedAs": { "type": "string" },
          "configFiles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "content"],
              "properties": {
                "path": { "type": "string" },
                "content": { "type": "string" }
              }
            }
          },
          "signals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type",
                "value",
                "line",
                "matchedPattern",
                "filePath"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "database-url",
                    "message-broker",
                    "cache-endpoint",
                    "search-endpoint",
                    "object-storage",
                    "service-endpoint",
                    "server-config",
                    "env-infrastructure"
                  ]
                },
                "value": { "type": "string" },
                "line": { "type": "integer" },
                "matchedPattern": { "type": "string" },
                "filePath": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
