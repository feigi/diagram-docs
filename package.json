{
  "name": "diagram-docs",
  "version": "0.1.0",
  "description": "C4 architecture diagram generator using D2 format",
  "type": "module",
  "bin": {
    "diagram-docs": "./dist/cli/index.js"
  },
  "scripts": {
    "prepare": "test -z \"$CI\" && husky || true",
    "prepack": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:quality": "vitest run tests/quality/",
    "test:correctness": "vitest run tests/quality/correctness.test.ts",
    "test:drift": "vitest run tests/quality/drift.test.ts",
    "test:tokens": "vitest run tests/quality/token-efficiency.test.ts",
    "bench": "vitest bench",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.13.0",
    "diff": "^8.0.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "gpt-tokenizer": "^3.4.0",
    "husky": "^9.1.7",
    "jsondiffpatch": "^0.7.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
